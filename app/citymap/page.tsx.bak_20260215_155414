    setMapThemeKey(key);
    setBaseStyle(theme.baseStyle);
    setMapColors(theme.colors);
    setMotorwayWidth(theme.motorwayWidth);
    setPrimaryRoadWidth(theme.primaryRoadWidth);
    setMinorRoadWidth(theme.minorRoadWidth);
  }, []);

