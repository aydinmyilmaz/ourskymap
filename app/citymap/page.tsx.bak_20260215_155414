                  value={cityQuery}
                  onChange={(e) => {
                    setCityQuery(e.target.value);
                    setSuggestionsOpen(true);
                  }}
                  onFocus={() => setSuggestionsOpen(true)}
                  placeholder="San Antonio, TX, USA"
                />

