                <b>{minorRoadWidth.toFixed(1)} px</b>
              </div>
            </div>

            <button type="button" className="checkoutBtn" onClick={() => void generate()} disabled={busy}>
              {busy ? 'Updating...' : 'Update Preview'}
            </button>
            {error ? <p className="error">{error}</p> : null}
          </section>
        </aside>
      </main>

      <style jsx>{`
        .designRoot :global(*),
