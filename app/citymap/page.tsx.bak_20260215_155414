    setZoom((prev) => clamp(prev + 1, MIN_MAP_ZOOM, MAX_MAP_ZOOM));
  }, []);

  const decreaseZoom = useCallback(() => {
    setZoom((prev) => clamp(prev - 1, MIN_MAP_ZOOM, MAX_MAP_ZOOM));
  }, []);

  const resetZoom = useCallback(() => {
    setZoom(DEFAULT_MAP_ZOOM);
