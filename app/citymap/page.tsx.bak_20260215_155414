  const hiddenMapContainersRef = useRef<Partial<Record<BaseStyleKey, HTMLDivElement>>>({});
  const lastSnapshotStateRef = useRef<{ baseStyle: BaseStyleKey; lon: number; lat: number; zoom: number } | null>(null);
